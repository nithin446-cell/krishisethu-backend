# KrishiSethu Backend - Environment Template
PORT=10000
NODE_ENV=development

# Supabase
SUPABASE_URL=https://nywdzfjizwgwhowuozei.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Supabase S3 (Storage)
SUPABASE_S3_ACCESS_KEY_ID=your_s3_access_key_id
SUPABASE_S3_SECRET_ACCESS_KEY=your_s3_secret_access_key

# Storage Buckets (Optional, defaults exist in code)
S3_BUCKET_CROP_PICTURES=crop_pictures
S3_BUCKET_USER_DOCUMENTS=user_documents
S3_BUCKET_ORDER_PHOTOS=order-photos
S3_BUCKET_KYC_DOCUMENTS=kyc-documents

# Razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret
RAZORPAY_X_ACCOUNT_NUMBER=your_razorpay_x_account

# Fast2SMS
FAST2SMS_API_KEY=your_fast2sms_api_key

# Data.gov.in (Mandi Prices)
DATA_GOV_API_KEY=your_data_gov_api_key

# Firebase (FCM)
# Paste the entire content of your firebase-service-account.json as a single-line JSON string
FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}

# Security
PENNY_HASH_SECRET=your_secure_hash_secret_string
ALLOWED_ORIGIN=*